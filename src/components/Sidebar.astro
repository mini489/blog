---
const items = [
	{
		title: "未定",
		body: "ここに何を入れるかは現時点では未定です。"
	},
	{
		title: "カテゴリー",
		body: "記事が増えたらカテゴリー分けしてここに表示する予定です。",
		list: ["記事1", "記事2", "記事3"]
	},
	{
		title: "未定",
		body: "ここに何を入れるかは現時点では未定です。"
	}
];
---

<aside class="sidebar">
	{items.map((item) => (
		<div class="sidebar-block">
			<h2>{item.title}</h2>

			{item.body && <p>{item.body}</p>}

			{item.list && (
				<ul>
					{item.list.map((text) => (
						<li>{text}</li>
					))}
				</ul>
			)}
		</div>
	))}
</aside>

<style>
	.sidebar {
		width: 300px;
		flex: 0 0 300px;
	}

	.sidebar-block {
		margin-bottom: 1.5rem;
		padding: 1rem;
		border: 1px solid rgba(var(--gray), 0.2);
		border-radius: 8px;
	}

	.sidebar-block h2 {
		margin: 0 0 0.5rem 0;
		font-size: 1rem;
	}
</style>
